// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum DeliveryStatus {
  PENDING
  PROGRESS
  DELIVERED
}

enum Roles {
  USER
  SUPERADMIN
  ADMIN
  MESSADMIN
  DELIVERYAGENT
}

model User {
  id                     String                  @id @default(uuid())
  name                   String
  phone                  String                  @unique
  email                  String                  @unique
  otp                    String?
  expiresAt              DateTime?
  is_verified            Boolean                 @default(false)
  is_active              Boolean                 @default(true)
  role                   Roles                   @default(USER)
  customerProfile        CustomerProfile?
  deliveryPartnerProfile DeliveryPartnerProfile?
  messAdminProfile       MessAdminProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerProfile {
  id                String   @id @default(uuid())
  walletAmount      Decimal  @default(0.00)
  address           String   @db.LongText
  current_location  String?
  latitude_logitude String?
  userId            String   @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  deliveries        Deliveries[]
  userSubscriptions UserSubscriptions[]
}

model UserSubscriptions {
  id                       String    @id @default(uuid())
  start_date               DateTime
  end_date                 DateTime?
  totalPrice               Decimal   @default(0.00)
  discount                 Decimal   @default(0.00)
  discountedPrice          Decimal   @default(0.00)
  deliveryPartnerProfileId String?
  planId                   String
  messId                   String
  is_active                Boolean   @default(true)
  customerProfileId        String?
  createdAt                DateTime  @default(now())

  DeliveryPartnerProfile DeliveryPartnerProfile? @relation(fields: [deliveryPartnerProfileId], references: [id])
  plan                   Plans                   @relation(fields: [planId], references: [id], onDelete: Cascade)
  CustomerProfile        CustomerProfile?        @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  mess                   Mess                    @relation(fields: [messId], references: [id], onDelete: Cascade)
}

model DeliveryPartnerProfile {
  id             String   @id @default(uuid())
  deliveryCounts Int?
  deliveryRegion String?
  address        String?  @db.LongText
  userId         String   @unique
  messId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  mess              Mess                @relation(fields: [messId], references: [id], onDelete: Cascade)
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries        Deliveries[]
  userSubscriptions UserSubscriptions[]
}

model Plans {
  id                String              @id @default(uuid())
  planName          String
  price             Decimal             @default(0.00)
  minPrice          Decimal?
  description       String?             @db.Text
  messId            String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  mess              Mess                @relation(fields: [messId], references: [id], onDelete: Cascade)
  images            PlanImages[]
  usersubscriptions UserSubscriptions[]
  deliveries        Deliveries[]
  Variation         Variation[]
}

model PlanImages {
  id        String   @id @default(uuid())
  planId    String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan Plans @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("plan_images")
}

model Variation {
  id          String   @id @default(uuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  plans       Plans[]
}

model Deliveries {
  id         String          @id @default(uuid())
  date       DateTime
  status     DeliveryStatus?
  action     String?
  customerId String
  planId     String
  partnerId  String?
  messId     String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  customer CustomerProfile         @relation(fields: [customerId], references: [id])
  plan     Plans                   @relation(fields: [planId], references: [id], onDelete: Cascade)
  partner  DeliveryPartnerProfile? @relation(fields: [partnerId], references: [id])
  mess     Mess                    @relation(fields: [messId], references: [id], onDelete: Cascade)
}

model Mess {
  id                     String                   @id @default(uuid())
  name                   String
  description            String?                  @db.Text
  address                String?                  @db.LongText
  phone                  String?
  email                  String?
  is_active              Boolean                  @default(true)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  plans                  Plans[]
  messAdmins             MessAdminProfile[]
  DeliveryPartnerProfile DeliveryPartnerProfile[]
  Deliveries             Deliveries[]
  UserSubscriptions      UserSubscriptions[]
}

model MessAdminProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messes    Mess[]
}
