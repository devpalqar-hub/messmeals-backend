// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum DeliveryStatus {
  PENDING
  PROGRESS
  DELIVERED
}

enum Role {
  USER
  SUPERADMIN
  MESSADMIN
  DELIVERYAGENT
}

enum ScheduleType {
  EVERYDAY
  CUSTOM
}

enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model User {
  id                     String                  @id @default(uuid())
  name                   String
  phone                  String                  @unique
  email                  String                  @unique
  otp                    String?
  expiresAt              DateTime?
  is_verified            Boolean                 @default(false)
  is_active              Boolean                 @default(true)
  role                   Role                    @default(USER)
  password               String?
  customerProfile        CustomerProfile?
  deliveryPartnerProfile DeliveryPartnerProfile?
  messAdminProfile       MessAdminProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerProfile {
  id                String   @id @default(uuid())
  walletAmount      Decimal? @default(0.00)
  address           String?  @db.LongText
  current_location  String?
  latitude_logitude String?
  userId            String   @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  deliveries        Deliveries[]
  userSubscriptions UserSubscriptions[]
  addresses         UserAddress[]
  Wallet            Wallet?
  Testimonials      Testimonials[]
}

model UserSubscriptions {
  id                       String       @id @default(uuid())
  start_date               DateTime
  end_date                 DateTime?
  pause_start_date         DateTime?
  pause_end_date           DateTime?
  cancellation_start_date  DateTime?
  cancellation_end_date    DateTime?
  scheduleType             ScheduleType @default(EVERYDAY)
  selectedDays             Json?
  totalPrice               Decimal      @default(0.00)
  discount                 Decimal      @default(0.00)
  discountedPrice          Decimal      @default(0.00)
  deliveryPartnerProfileId String?
  userAddressId            String?
  planId                   String
  messId                   String
  is_active                Boolean      @default(true)
  cancelled_on             DateTime?
  customerProfileId        String?
  deliveryPriority         Int?

  createdAt DateTime @default(now())

  isActive Boolean @default(true)

  DeliveryPartnerProfile DeliveryPartnerProfile? @relation(fields: [deliveryPartnerProfileId], references: [id])
  plan                   Plans                   @relation(fields: [planId], references: [id], onDelete: Cascade)
  CustomerProfile        CustomerProfile?        @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  mess                   Mess                    @relation(fields: [messId], references: [id], onDelete: Cascade)
  UserAddress            UserAddress?            @relation(fields: [userAddressId], references: [id])
  deliveries             Deliveries[]

  @@unique([messId, deliveryPriority])
  @@index([messId, deliveryPriority])
}

model DeliveryPartnerProfile {
  id             String   @id @default(uuid())
  deliveryCounts Int?
  deliveryRegion String?
  isonline       Boolean  @default(true)
  address        String?  @db.LongText
  userId         String   @unique
  messId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  mess              Mess                @relation(fields: [messId], references: [id], onDelete: Cascade)
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries        Deliveries[]
  userSubscriptions UserSubscriptions[]
  Testimonials      Testimonials[]
}

model Plans {
  id          String   @id @default(uuid())
  planName    String
  price       Decimal  @default(0.00)
  minPrice    Decimal?
  description String?  @db.Text
  messId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  mess        Mess     @relation(fields: [messId], references: [id], onDelete: Cascade)

  isMonthlyPlan Boolean @default(false)
  isDailyPlan   Boolean @default(true)
  isActive      Boolean @default(true)

  images            PlanImages[]
  usersubscriptions UserSubscriptions[]
  deliveries        Deliveries[]
  Variation         Variation[]
}

model PlanImages {
  id        String   @id @default(uuid())
  planId    String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan Plans @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("plan_images")
}

model Variation {
  id          String   @id @default(uuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  plans       Plans[]

  isActive Boolean @default(true)
}

model Deliveries {
  id             String          @id @default(uuid())
  date           DateTime
  status         DeliveryStatus?
  action         String?
  customerId     String
  planId         String
  partnerId      String?
  messId         String
  subscriptionId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  isActive Boolean @default(true)

  customer          CustomerProfile         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  plan              Plans                   @relation(fields: [planId], references: [id], onDelete: Cascade)
  partner           DeliveryPartnerProfile? @relation(fields: [partnerId], references: [id])
  mess              Mess                    @relation(fields: [messId], references: [id], onDelete: Cascade)
  UserSubscriptions UserSubscriptions?      @relation(fields: [subscriptionId], references: [id])
}

model Mess {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text
  address     String? @db.LongText
  phone       String?
  email       String?
  is_active   Boolean @default(true)

  is_verified  Boolean      @default(false)
  openingHours Json?
  images       MessImages[]
  location     String?
  categories   Category[]

  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  plans                  Plans[]
  messAdmins             MessAdminProfile[]
  DeliveryPartnerProfile DeliveryPartnerProfile[]
  Deliveries             Deliveries[]
  UserSubscriptions      UserSubscriptions[]
  Testimonials           Testimonials[]
}

model MessImages {
  id        String   @id @default(uuid())
  messId    String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mess Mess @relation(fields: [messId], references: [id], onDelete: Cascade)

  @@map("mess_images")
}

model MessAdminProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messes    Mess[]
}

model UserAddress {
  id               String   @id @default(uuid())
  name             String
  street           String
  townOrcity       String
  country          String?
  postcode         String
  landmark         String?
  latitudeLogitude String?
  phone            String?
  email            String?
  locationLink     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  isActive Boolean @default(true)

  User      CustomerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String

  subscriptions UserSubscriptions[]
}

model Wallet {
  id           String          @id @default(uuid())
  profile      CustomerProfile @relation(fields: [userId], references: [id])
  userId       String          @unique
  walletAmount Decimal         @default(0.00)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  transactions Transaction[]
}

model Transaction {
  id           String   @id @default(uuid())
  wallet       Wallet   @relation(fields: [walletId], references: [id])
  walletId     String
  amount       Decimal  @default(0.00) // smallest unit; positive for credit, negative for debit
  balanceAfter Decimal  @default(0.00) // wallet balance after transaction, stored to allow auditing
  meta         Json? // optional metadata: { fromUserId, toUserId, note, externalId }
  createdAt    DateTime @default(now())
}

model PhoneNumbers {
  id    String @id @default(uuid())
  phone String @unique
}

model Category {
  id          String  @id @default(uuid())
  name        String
  image       String?
  description String?
  isActive    Boolean @default(true)
  mess        Mess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonials {
  id              String   @id @default(uuid())
  messId          String
  ratings         Int
  reviews         String
  customerId      String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  DeliveryagentId String?
  isActive        Boolean  @default(true)

  mess            Mess                    @relation(fields: [messId], references: [id], onDelete: Cascade)
  customer        CustomerProfile         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deliveryPartner DeliveryPartnerProfile? @relation(fields: [DeliveryagentId], references: [id], onDelete: Cascade)
}
